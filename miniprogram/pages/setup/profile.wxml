<view class="setup-page">
  <view class="profile-hero">
    <image class="profile-hero-img" src="../../images/ui/profile-hero.png" mode="aspectFill"/>
  </view>

  <view class="profile-card">
    <view class="avatar-section">
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image class="avatar-img" src="{{avatarUrl}}" mode="aspectFill" wx:if="{{avatarUrl}}"/>
        <view class="avatar-placeholder" wx:else>
          <van-icon name="plus" size="54rpx" color="#ff8a68"/>
        </view>
        <view class="camera-badge">
          <van-icon name="photograph" size="34rpx" color="#fff"/>
        </view>
      </button>
      <text class="avatar-hint">点击选择头像</text>
    </view>

    <view class="field-row">
      <text class="field-label">昵称</text>
      <view class="nickname-box">
        <input class="nickname-input" type="nickname" placeholder="请输入昵称" maxlength="16" value="{{nickName}}" bindinput="onNickInput"/>
        <text class="nickname-count">{{nickName.length || 0}}/16</text>
      </view>
    </view>

    <view class="setup-footer">
      <van-button type="primary" block round color="#FF5032" custom-style="background: linear-gradient(135deg, #ff5032, #ff6f3d); border: none;" bindtap="onSubmit" disabled="{{!avatarUrl || !nickName}}" loading="{{submitting}}">完成</van-button>
    </view>
  </view>
</view>

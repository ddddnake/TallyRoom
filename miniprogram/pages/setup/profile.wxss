.setup-page {
  min-height: 100vh;
  padding: 0 24rpx 48rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 10% 12%, rgba(255, 80, 50, 0.11) 0, rgba(255, 80, 50, 0) 240rpx),
    radial-gradient(circle at 90% 2%, rgba(255, 204, 132, 0.25) 0, rgba(255, 204, 132, 0) 280rpx),
    var(--color-bg);
}

.profile-hero {
  height: 340rpx;
  margin: 24rpx 0 0;
  border-radius: 34rpx 34rpx 0 0;
  overflow: hidden;
  background: #fff1e3;
  box-shadow: var(--shadow-soft);
}
.profile-hero-img {
  width: 100%;
  height: 100%;
  background: #fff1e3;
}

.profile-card {
  position: relative;
  margin-top: 18rpx;
  padding: 44rpx 34rpx 38rpx;
  border-radius: 42rpx;
  background: #fff;
  box-shadow: var(--shadow-card);
}
.profile-card::before {
  content: '';
  position: absolute;
  left: 70rpx;
  top: -2rpx;
  width: 120rpx;
  height: 8rpx;
  border-radius: var(--radius-pill);
  background: linear-gradient(90deg, #ff5032, #ffb27c);
}

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}
.avatar-btn {
  position: relative;
  width: 178rpx;
  height: 178rpx;
  border-radius: 50%;
  border: 8rpx solid #fff;
  background: #fff5ee;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  box-shadow: 0 12rpx 36rpx rgba(80, 50, 24, 0.14);
  overflow: visible;
}
.avatar-btn::after { border: none; }
.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}
.avatar-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #fff8ef, #ffe9dc);
}
.camera-badge {
  position: absolute;
  right: -4rpx;
  bottom: 8rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff5032, #ff7044);
  border: 5rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 16rpx rgba(255, 80, 50, 0.28);
}
.avatar-hint {
  margin-top: 18rpx;
  color: var(--color-text);
  font-size: 28rpx;
  font-weight: 700;
}


.field-row {
  margin-top: 6rpx;
}
.field-label {
  display: block;
  color: var(--color-text);
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 14rpx;
}
.nickname-box {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid #f0e5da;
  border-radius: 22rpx;
  background: #fffaf5;
  box-sizing: border-box;
}
.nickname-input {
  flex: 1;
  height: 100%;
  color: var(--color-text);
  font-size: 30rpx;
}
.nickname-count {
  color: #b6aaa0;
  font-size: 24rpx;
  margin-left: 18rpx;
}

.setup-footer {
  margin-top: 36rpx;
}
.setup-footer van-button {
  box-shadow: 0 12rpx 26rpx rgba(255, 80, 50, 0.26);
}

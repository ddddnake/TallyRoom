<view class="history-page">
  <view class="history-hero">
    <view class="history-copy">
      <view class="history-title">历史房间</view>
      <view class="history-subtitle">回顾每一次好友局</view>
    </view>
    <image class="history-brand" src="../../images/ui/brand-mahjong.png" mode="aspectFit"/>
  </view>

  <view class="loading-card" wx:if="{{loading && !rooms.length}}">
    <van-loading size="36rpx" color="#ff5032">加载中...</van-loading>
  </view>

  <view class="empty-card" wx:if="{{!rooms.length && !loading}}">
    <van-empty description="还没有参与过房间" />
  </view>

  <view class="room-list" wx:if="{{rooms.length}}">
    <van-swipe-cell wx:for="{{rooms}}" wx:key="_id" right-width="{{ 72 }}" class="room-swipe">
      <view class="room-item" bindtap="onTapRoom" data-id="{{item._id}}" data-state="{{item.state}}" data-status="{{item.statusType}}" data-name="{{item.name}}">
        <view class="room-thumb">
          <image src="../../images/rooms/room-1.png" mode="aspectFill"/>
        </view>
        <view class="room-info">
          <view class="room-name-row">
            <text class="room-name">{{item.name}}</text>
          </view>
          <view class="room-meta">
            <text class="room-date">{{item.dateText}}</text>
            <text class="room-duration">{{item.durationText}}</text>
          </view>
        </view>
        <view class="room-side">
          <text class="room-status status-{{item.statusType}}">{{item.statusLabel}}</text>
          <view class="room-score {{item.myScore >= 0 ? 'positive' : 'negative'}}">
            {{item.myScoreText}}
          </view>
        </view>
      </view>
      <view slot="right" class="room-delete" catchtap="onDeleteRoom" data-id="{{item._id}}">
        <van-icon name="delete-o" size="34rpx" color="#fff"/>
        <text>删除</text>
      </view>
    </van-swipe-cell>
  </view>
</view>

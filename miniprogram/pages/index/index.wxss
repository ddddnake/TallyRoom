.index-page {
  min-height: 100vh;
  padding: 32rpx 32rpx 48rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 12% 4%, rgba(255, 133, 78, 0.16) 0, rgba(255, 133, 78, 0) 220rpx),
    radial-gradient(circle at 94% 14%, rgba(255, 204, 132, 0.24) 0, rgba(255, 204, 132, 0) 260rpx),
    var(--color-bg);
}

.hero-card {
  position: relative;
  overflow: hidden;
  min-height: 330rpx;
  border-radius: 40rpx;
  padding: 34rpx 30rpx 0;
  background: linear-gradient(150deg, #fffaf2 0%, #fff2e5 52%, #ffe6d6 100%);
  box-shadow: var(--shadow-card);
}
.hero-card::before,
.hero-card::after {
  content: '';
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 80, 50, 0.08);
}
.hero-card::before {
  width: 220rpx;
  height: 220rpx;
  left: -70rpx;
  bottom: -90rpx;
}
.hero-card::after {
  width: 160rpx;
  height: 160rpx;
  right: -40rpx;
  top: -44rpx;
}
.hero-copy {
  position: relative;
  z-index: 2;
  width: 54%;
}
.hero-eyebrow {
  display: inline-flex;
  padding: 8rpx 18rpx;
  border-radius: var(--radius-pill);
  background: rgba(255, 80, 50, 0.1);
  color: var(--color-primary);
  font-size: 22rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}
.welcome {
  display: block;
  color: var(--color-text);
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.22;
}
.subtitle {
  display: block;
  margin-top: 14rpx;
  color: var(--color-text-secondary);
  font-size: 26rpx;
  line-height: 1.45;
}
.hero-image {
  position: absolute;
  right: -54rpx;
  bottom: -12rpx;
  z-index: 1;
  width: 560rpx;
  height: 304rpx;
}

.stats-card {
  position: relative;
  margin-top: 26rpx;
  padding: 30rpx 26rpx 34rpx;
  border-radius: 34rpx;
  background: #fff;
  box-shadow: var(--shadow-card);
}
.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 26rpx;
}
.section-title {
  color: var(--color-text);
  font-size: 30rpx;
  font-weight: 800;
}
.section-meta {
  color: #b3a79b;
  font-size: 23rpx;
}
.stats-grid {
  display: flex;
  align-items: stretch;
}
.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
}
.stats-divider {
  width: 1rpx;
  margin: 16rpx 8rpx 0;
  background: #f0e8df;
}
.stats-icon {
  width: 58rpx;
  height: 58rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 14rpx;
}
.stats-icon-room { background: #fff0eb; }
.stats-icon-score { background: #fff6e4; }
.stats-label {
  color: var(--color-text-secondary);
  font-size: 24rpx;
  margin-bottom: 8rpx;
}
.stats-number-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
}
.stats-value {
  color: var(--color-text);
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1;
}
.stats-value.positive { color: var(--color-primary); }
.stats-value.negative { color: var(--color-success); }
.stats-unit {
  color: var(--color-text-secondary);
  font-size: 23rpx;
  margin-left: 6rpx;
}

.action-stack {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.action-card {
  display: flex;
  align-items: center;
  min-height: 126rpx;
  border-radius: 28rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  box-shadow: var(--shadow-soft);
}
.action-card-primary {
  background: linear-gradient(135deg, var(--color-primary), #ff6f3d);
  color: #fff;
}
.action-card-secondary {
  background: #fff;
  border: 1rpx solid rgba(241, 231, 220, 0.9);
}
.action-card:active { transform: scale(0.99); }
.action-icon {
  width: 78rpx;
  height: 78rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 22rpx;
}
.action-icon-primary { background: rgba(255, 255, 255, 0.18); }
.action-icon-secondary { background: #fff4ee; }
.action-copy {
  flex: 1;
  min-width: 0;
}
.action-title {
  display: block;
  color: var(--color-text);
  font-size: 32rpx;
  font-weight: 800;
}
.action-desc {
  display: block;
  margin-top: 8rpx;
  color: var(--color-text-secondary);
  font-size: 24rpx;
  line-height: 1.3;
}
.primary-title,
.primary-desc { color: #fff; }
.primary-desc { opacity: 0.86; }

.compliance-tip {
  display: flex;
  gap: 12rpx;
  margin-top: 32rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 248, 230, 0.92);
  border: 1rpx solid rgba(250, 140, 22, 0.14);
  color: #8a6a35;
  font-size: 22rpx;
  line-height: 1.6;
}
.compliance-tip text { flex: 1; }

.join-popup {
  width: 600rpx;
  padding: 28rpx 34rpx 38rpx;
  border-radius: 34rpx;
  background: #fff;
  box-sizing: border-box;
  box-shadow: 0 18rpx 60rpx rgba(0, 0, 0, 0.18);
}
.join-visual {
  height: 150rpx;
  margin-bottom: 18rpx;
  border-radius: 26rpx;
  overflow: hidden;
  background: #fff7ed;
}
.join-visual image {
  width: 100%;
  height: 100%;
}
.join-title {
  color: var(--color-text);
  font-size: 34rpx;
  font-weight: 800;
  text-align: center;
  margin-bottom: 12rpx;
}
.join-hint {
  color: var(--color-text-secondary);
  font-size: 24rpx;
  text-align: center;
  line-height: 1.5;
  margin-bottom: 30rpx;
}
.join-input {
  width: 100%;
  height: 88rpx;
  margin-bottom: 30rpx;
  border: 2rpx solid #f0e4d9;
  border-radius: 18rpx;
  background: #fffaf5;
  box-sizing: border-box;
  text-align: center;
  color: var(--color-text);
  font-size: 38rpx;
  font-weight: 700;
  letter-spacing: 12rpx;
  text-transform: uppercase;
}
.join-close {
  text-align: center;
  margin-top: 30rpx;
}

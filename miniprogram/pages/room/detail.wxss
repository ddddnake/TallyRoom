.room-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 8% 4%, rgba(255, 80, 50, 0.1) 0, rgba(255, 80, 50, 0) 230rpx),
    radial-gradient(circle at 94% 12%, rgba(255, 204, 132, 0.22) 0, rgba(255, 204, 132, 0) 260rpx),
    var(--color-bg);
}
.room-loading-overlay {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  background: var(--color-bg);
}

.room-top {
  flex-shrink: 0;
  padding: 14rpx 20rpx 0;
}
.room-title-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 0 24rpx 10rpx;
}
.room-title {
  color: var(--color-text);
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  min-width: 0;
  max-width: 430rpx;
}
.room-code {
  color: var(--color-text-secondary);
  font-size: 22rpx;
  flex-shrink: 0;
  white-space: nowrap;
}

.users-panel {
  margin-top: 0;
  padding: 16rpx 0 14rpx;
  border-radius: 30rpx;
  background: #fff;
  box-shadow: var(--shadow-soft);
}
.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 22rpx 12rpx;
}
.panel-title {
  color: var(--color-text);
  font-size: 28rpx;
  font-weight: 800;
}
.panel-meta {
  color: var(--color-text-secondary);
  font-size: 23rpx;
}
.users-scroll {
  display: flex;
  white-space: nowrap;
  padding: 0 20rpx;
  box-sizing: border-box;
  height: 180rpx;
}
.user-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 124rpx;
  min-height: 162rpx;
  flex-shrink: 0;
  margin-right: 16rpx;
  padding: 10rpx 8rpx 8rpx;
  border-radius: 24rpx;
  background: transparent;
  box-sizing: border-box;
  transition: transform 0.1s;
}
.user-card:active { transform: scale(0.96); }
.user-card-left .user-avatar,
.user-card-left .user-name,
.user-card-left .user-score {
  opacity: 0.45;
  filter: grayscale(0.5);
}
.user-card-left:active { transform: none; }
.user-left-tag {
  margin-top: 4rpx;
  padding: 2rpx 12rpx;
  border-radius: 18rpx;
  background: #efe7df;
  color: #8a7a6a;
  font-size: 18rpx;
  font-weight: 600;
  line-height: 1.4;
}
.user-avatar-wrap { position: relative; }
.user-avatar,
.feature-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background-color: #f3ede5;
  overflow: hidden;
  box-shadow: 0 6rpx 18rpx rgba(80, 50, 24, 0.08);
}
.user-avatar-img {
  width: 100%;
  height: 100%;
}
.owner-badge {
  position: absolute;
  right: -10rpx;
  top: -16rpx;
  font-size: 28rpx;
  line-height: 1;
}
.owner-crown {
  margin-right: 4rpx;
  font-size: 24rpx;
}
.user-name {
  max-width: 104rpx;
  margin-top: 8rpx;
  color: var(--color-text);
  font-size: 22rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.user-score {
  width: 100%;
  margin-top: 4rpx;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.15;
  text-align: center;
  white-space: normal;
  word-break: break-all;
  overflow-wrap: break-word;
}
.user-score.positive { color: var(--color-primary); }
.user-score.negative { color: var(--color-success); }
.feature-card { background: transparent; }
.feature-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
}
.invite-avatar {
  background: #f8f8f8;
  border: 2rpx dashed #ddd;
  box-sizing: border-box;
}
.feature-sub {
  margin-top: 8rpx;
  font-size: 21rpx;
  color: var(--color-text-secondary);
}
.invite-plus {
  font-size: 72rpx;
  color: #999;
  font-weight: 500;
  line-height: 1;
}
.invite-card::after { border: none; }

.tea-summary-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
  padding: 14rpx 20rpx;
  border-radius: 26rpx;
  background: #fff;
  box-shadow: var(--shadow-soft);
}
.tea-summary-left {
  display: flex;
  align-items: center;
  min-width: 0;
}
.tea-summary-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 24rpx;
  background: #fff1d9;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 18rpx;
}
.tea-summary-icon image {
  width: 46rpx;
  height: 46rpx;
}
.tea-summary-copy {
  min-width: 0;
}
.tea-summary-title {
  color: var(--color-text);
  font-size: 28rpx;
  font-weight: 800;
}
.tea-summary-sub {
  margin-top: 4rpx;
  color: var(--color-text-secondary);
  font-size: 22rpx;
}
.tea-summary-right {
  text-align: right;
  flex-shrink: 0;
  margin-left: 18rpx;
}
.tea-summary-total {
  color: var(--color-text-secondary);
  font-size: 22rpx;
}
.tea-summary-total text {
  color: var(--color-primary);
  font-size: 30rpx;
  font-weight: 800;
  padding: 0 4rpx;
}
.tea-summary-action {
  margin-top: 6rpx;
  color: #b6aaa0;
  font-size: 22rpx;
}

.action-hint {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin: 12rpx 20rpx 0;
  padding: 12rpx 18rpx;
  border-radius: 22rpx;
  background: #fff8e6;
  border: 1rpx solid rgba(250, 140, 22, 0.12);
  color: #8a6a35;
  font-size: 21rpx;
  line-height: 1.4;
}
.action-hint text { flex: 1; }

.msg-scroll {
  flex: 1;
  min-height: 0;
  padding: 14rpx 20rpx 18rpx;
  box-sizing: border-box;
  overflow-y: auto;
}
.message-list {
  padding-bottom: 12rpx;
}
.msg-group {
  margin-bottom: 22rpx;
  padding: 14rpx 16rpx 8rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.55);
  border: 1rpx solid rgba(255, 80, 50, 0.08);
}
.msg-group-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 0 6rpx 10rpx;
}
.msg-group-label {
  color: #8a6a35;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}
.msg-group-count {
  color: var(--color-text-secondary);
  font-size: 21rpx;
}
.msg-group-body .msg-item:last-child {
  margin-bottom: 4rpx;
}
.msg-item {
  margin-bottom: 16rpx;
}
.msg-pending .msg-text {
  opacity: 0.55;
}
.msg-time {
  display: inline-flex;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-pill);
  background: rgba(255, 255, 255, 0.72);
  color: #b6aaa0;
  font-size: 20rpx;
  margin-bottom: 8rpx;
}
.msg-text {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  min-height: 72rpx;
  padding: 14rpx 18rpx;
  border-radius: 22rpx;
  background: #fff;
  box-shadow: var(--shadow-soft);
  color: var(--color-text);
  font-size: 25rpx;
  line-height: 1.45;
  box-sizing: border-box;
}
.msg-main {
  flex: 1;
  min-width: 0;
  padding-right: 18rpx;
}
.msg-amount-side {
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  min-width: 128rpx;
  flex-shrink: 0;
  text-align: right;
}
.msg-part-name { color: var(--color-text); font-weight: 800; }
.msg-part-arrow { color: #c6b9ad; padding: 0 4rpx; }
.msg-part-amount {
  color: #ff2a1f;
  font-weight: 800;
  font-size: 38rpx;
  padding: 0 3rpx;
}
.msg-unit {
  color: var(--color-text-secondary);
  font-size: 24rpx;
  margin-left: 2rpx;
}
.msg-part-txt { color: #665d55; }
.empty-card {
  margin-top: 36rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: var(--shadow-soft);
  overflow: hidden;
}

.footer {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 0 24rpx 20rpx;
  padding: 18rpx;
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -8rpx 34rpx rgba(80, 50, 24, 0.08);
}
.footer-btn {
  flex: 1;
  height: 78rpx;
  border-radius: var(--radius-pill);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 27rpx;
  font-weight: 700;
}
.footer-primary {
  background: linear-gradient(135deg, var(--color-primary), #ff6f3d);
  color: #fff;
  box-shadow: 0 10rpx 24rpx rgba(255, 80, 50, 0.22);
}
.footer-secondary {
  background: #f8f5f0;
  color: #333;
}
.footer-icon {
  position: relative;
  width: 30rpx;
  height: 30rpx;
  flex-shrink: 0;
}
.exit-icon::before {
  content: '';
  position: absolute;
  left: 2rpx;
  top: 5rpx;
  width: 13rpx;
  height: 20rpx;
  border: 3rpx solid #333;
  border-right: none;
  border-radius: 3rpx 0 0 3rpx;
  box-sizing: border-box;
}
.exit-icon::after {
  content: '';
  position: absolute;
  right: 1rpx;
  top: 13rpx;
  width: 20rpx;
  height: 3rpx;
  background: #333;
  border-radius: 3rpx;
  box-shadow: 7rpx -6rpx 0 -2rpx #333, 7rpx 6rpx 0 -2rpx #333;
}
.power-icon {
  border: 3rpx solid #333;
  border-top-color: transparent;
  border-radius: 50%;
  box-sizing: border-box;
}
.power-icon::before {
  content: '';
  position: absolute;
  left: 50%;
  top: -1rpx;
  width: 3rpx;
  height: 15rpx;
  margin-left: -1.5rpx;
  border-radius: 3rpx;
  background: #333;
}
.footer-single { max-width: none; }
.readonly-hint { justify-content: center; }

.popup-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: #fff0eb;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 18rpx;
}
.quick-score-popup {
  width: 590rpx;
  padding: 44rpx 38rpx 34rpx;
  border-radius: 34rpx;
  background: #fff;
  text-align: center;
  box-shadow: 0 18rpx 60rpx rgba(0, 0, 0, 0.16);
  box-sizing: border-box;
}
.quick-score-title {
  color: var(--color-text);
  font-size: 34rpx;
  font-weight: 800;
  margin-bottom: 10rpx;
}
.quick-score-hint {
  color: var(--color-text-secondary);
  font-size: 25rpx;
  margin-bottom: 28rpx;
}
.quick-score-input {
  width: 100%;
  height: 92rpx;
  margin-bottom: 30rpx;
  border: 2rpx solid #f0e5da;
  border-radius: 20rpx;
  background: #fffaf5;
  box-sizing: border-box;
  text-align: center;
  color: var(--color-text);
  font-size: 42rpx;
  font-weight: 800;
}
.quick-score-actions,
.profile-editor-actions,
.invite-actions {
  display: flex;
  gap: 22rpx;
}
.quick-score-actions van-button,
.profile-editor-actions van-button {
  flex: 1;
}

.profile-editor,
.invite-popup {
  width: 610rpx;
  padding: 40rpx 38rpx 34rpx;
  border-radius: 34rpx;
  background: #fff;
  box-sizing: border-box;
  box-shadow: 0 18rpx 60rpx rgba(0, 0, 0, 0.16);
}
.profile-editor-title,
.invite-title {
  color: var(--color-text);
  font-size: 34rpx;
  font-weight: 800;
  text-align: center;
  margin-bottom: 28rpx;
}
.profile-avatar-btn {
  width: 168rpx;
  height: 168rpx;
  border-radius: 50%;
  border: 6rpx solid #fff;
  background: #fff5ee;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0 auto;
  overflow: hidden;
  box-shadow: 0 10rpx 30rpx rgba(80, 50, 24, 0.14);
}
.profile-avatar-btn::after,
.invite-share-btn::after { border: none; }
.profile-avatar-img { width: 100%; height: 100%; }
.profile-avatar-hint {
  margin: 18rpx 0 28rpx;
  color: var(--color-text-secondary);
  font-size: 24rpx;
  text-align: center;
}
.profile-nick-input {
  width: 100%;
  height: 84rpx;
  margin-bottom: 30rpx;
  border: 2rpx solid #f0e5da;
  border-radius: 20rpx;
  background: #fffaf5;
  box-sizing: border-box;
  text-align: center;
  color: var(--color-text);
  font-size: 30rpx;
}
.profile-editor-tip {
  margin-top: 22rpx;
  color: #b6aaa0;
  font-size: 22rpx;
  line-height: 1.55;
  text-align: center;
}

.invite-hero {
  height: 138rpx;
  margin-bottom: 20rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #fff7ed;
}
.invite-hero-icon {
  display: flex;
  align-items: center;
  justify-content: center;
}
.invite-hero-icon image {
  width: 96rpx;
  height: 96rpx;
}
.invite-hero image,
.invite-qrcode { width: 100%; height: 100%; }
.invite-hero-icon image { width: 96rpx; height: 96rpx; }
.invite-qrcode-wrap {
  width: 360rpx;
  height: 360rpx;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 26rpx;
  background: #fffaf5;
  border: 2rpx solid #f0e5da;
  overflow: hidden;
}
.invite-qrcode { width: 320rpx; height: 320rpx; }
.invite-qrcode-loading {
  color: var(--color-text-secondary);
  font-size: 24rpx;
}
.invite-qrcode-tip {
  text-align: center;
  color: var(--color-text-secondary);
  font-size: 24rpx;
  margin-top: 16rpx;
}
.invite-code-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-top: 28rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: #fffaf5;
}
.invite-code-label { color: var(--color-text-secondary); font-size: 25rpx; }
.invite-code-value {
  color: var(--color-text);
  font-size: 36rpx;
  font-weight: 800;
  letter-spacing: 6rpx;
}
.invite-code-copy {
  color: var(--color-primary);
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-pill);
}
.invite-actions { margin-top: 28rpx; }
.invite-share-btn,
.invite-close-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: var(--radius-pill);
  font-size: 28rpx;
  text-align: center;
  box-sizing: border-box;
}
.invite-share-btn {
  background: var(--color-primary);
  color: #fff;
  font-weight: 700;
}
.invite-close-btn {
  background: #f8f5f0;
  color: #666;
}

.settle-popup {
  padding: 36rpx 28rpx 32rpx;
  max-height: 85vh;
  overflow-y: auto;
  box-sizing: border-box;
}
.settle-title {
  color: var(--color-text);
  font-size: 36rpx;
  font-weight: 800;
  text-align: center;
  margin-bottom: 24rpx;
}
.settle-tea-tip {
  color: #8a6a35;
  font-size: 24rpx;
  background: #fff8e6;
  border-radius: 20rpx;
  padding: 18rpx 22rpx;
  margin-bottom: 24rpx;
  line-height: 1.6;
}
.settle-tea-amount { color: #ff2a1f; font-weight: 800; padding: 0 4rpx; }
.settle-section-title {
  color: var(--color-text-secondary);
  font-size: 25rpx;
  font-weight: 800;
  margin: 26rpx 4rpx 12rpx;
}
.settle-list,
.settle-transfers {
  background: #fff;
  border-radius: 24rpx;
  padding: 6rpx 20rpx;
  box-shadow: var(--shadow-soft);
}
.settle-row,
.settle-transfer {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0e5da;
}
.settle-row:last-child,
.settle-transfer:last-child { border-bottom: none; }
.settle-name,
.settle-from,
.settle-to {
  color: var(--color-text);
  font-size: 28rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.settle-name { flex: 1; }
.settle-detail {
  margin-right: 16rpx;
  color: var(--color-text-secondary);
  font-size: 22rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}
.settle-final {
  min-width: 96rpx;
  text-align: right;
  font-size: 36rpx;
  font-weight: 800;
}
.settle-final.positive { color: #ff2a1f; }
.settle-final.negative { color: #52c41a; }
.settle-empty {
  border-radius: 24rpx;
  background: #fff;
  color: var(--color-text-secondary);
  text-align: center;
  padding: 36rpx 0;
  font-size: 28rpx;
  box-shadow: var(--shadow-soft);
}
.settle-from,
.settle-to {
  flex-shrink: 1;
  min-width: 0;
}
.settle-arrow {
  color: #c6b9ad;
  padding: 0 12rpx;
  flex-shrink: 0;
}
.settle-amount {
  margin-left: auto;
  padding-left: 16rpx;
  color: #ff2a1f;
  font-size: 32rpx;
  font-weight: 800;
}
.settle-unit {
  color: var(--color-text-secondary);
  font-size: 24rpx;
  margin-left: 4rpx;
}
.settle-close-btn {
  margin-top: 30rpx;
  height: 82rpx;
  line-height: 82rpx;
  border-radius: var(--radius-pill);
  background: #fff;
  color: #666;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: var(--shadow-soft);
}

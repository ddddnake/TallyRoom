.room-page {
  display: flex; flex-direction: column; height: 100vh;
  background: var(--color-bg);
}

.users { padding: 24rpx; flex-shrink: 0; }
.users-scroll { display: flex; white-space: nowrap; }

.user-card {
  display: inline-flex; flex-direction: column; align-items: center;
  width: 160rpx; flex-shrink: 0; margin-right: 16rpx;
}
.user-avatar-wrap {
  position: relative;
}
.user-avatar {
  width: 100rpx; height: 100rpx; border-radius: 50%;
  background-color: #eee;
  overflow: hidden;
}
.user-avatar-img {
  width: 100%; height: 100%;
}
.owner-tag { position: absolute; right: -20rpx; top: -20rpx; }
.user-name { font-size: 26rpx; color: #333; margin-top: 8rpx; max-width: 140rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.user-score { font-size: 32rpx; font-weight: 600; margin-top: 4rpx; }
.user-score.positive { color: var(--color-primary); }
.user-score.negative { color: #52c41a; }

.tea-avatar { background: #f5f5dc; display: flex; align-items: center; justify-content: center; }
.invite-avatar { background: #f0f8ff; display: flex; align-items: center; justify-content: center; }
.invite-plus {
  font-size: 72rpx;
  color: #999;
  font-weight: 500;
  line-height: 1;
}
.invite-card::after { border: none; }

.msg-scroll { flex: 1; padding: 20rpx 32rpx; overflow-y: auto; }
.msg-item { margin-bottom: 24rpx; }
.msg-time { font-size: 22rpx; color: #bbb; margin-bottom: 4rpx; }
.msg-text { font-size: 28rpx; color: #333; background: #fff; padding: 12rpx 20rpx; border-radius: 8rpx; display: inline-block; }
.msg-part-name { color: #333; font-weight: 600; }
.msg-part-arrow { color: #bbb; padding: 0 4rpx; }
.msg-part-amount {
  color: #ff2a1f;
  font-weight: 700;
  font-size: 32rpx;
  padding: 0 4rpx;
}
.msg-part-txt { color: #555; }

.footer {
  display: flex; justify-content: space-around; align-items: center;
  height: 100rpx; background: #fff; border-top: 1rpx solid #eee;
  flex-shrink: 0; padding-bottom: env(safe-area-inset-bottom);
}
.footer-btn { font-size: 28rpx; color: var(--color-primary); padding: 16rpx 32rpx; }
.readonly-hint { justify-content: center; font-size: 26rpx; color: #999; }

.score-popup {
  width: 580rpx; background: #fff; border-radius: 24rpx; padding: 48rpx 32rpx 32rpx;
}
.score-hint { font-size: 26rpx; color: #999; text-align: center; margin-bottom: 32rpx; }
.score-item { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx; }
.score-name { font-size: 30rpx; color: #333; flex-shrink: 0; width: 100rpx; }
.score-input {
  flex: 1; height: 64rpx; border: 2rpx solid #eee; border-radius: 8rpx;
  padding: 0 16rpx; font-size: 28rpx; text-align: right;
}
.score-close { text-align: center; margin-top: 24rpx; }

/* 快速计分弹层 */
.action-hint {
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  padding: 12rpx 0;
  background: #fff;
}

.quick-score-popup {
  width: 560rpx; background: #fff; border-radius: 24rpx;
  padding: 48rpx 40rpx 32rpx; text-align: center;
}
.quick-score-title {
  font-size: 34rpx; font-weight: 600; color: #333; margin-bottom: 12rpx;
}
.quick-score-hint {
  font-size: 26rpx; color: #999; margin-bottom: 32rpx;
}
.quick-score-input {
  width: 100%; height: 88rpx;
  border: 2rpx solid #eee; border-radius: 12rpx;
  text-align: center; font-size: 40rpx;
  margin-bottom: 32rpx;
}
.quick-score-actions {
  display: flex; gap: 24rpx; justify-content: space-around;
}
.quick-score-actions van-button {
  flex: 1;
}

.user-card { transition: transform 0.1s; }
.user-card:active { transform: scale(0.95); }

/* 个人资料编辑弹层 */
.profile-editor {
  width: 580rpx; background: #fff; border-radius: 24rpx;
  padding: 40rpx 40rpx 32rpx;
}
.profile-editor-title {
  font-size: 32rpx; font-weight: 600; text-align: center;
  margin-bottom: 32rpx;
}
.profile-avatar-btn {
  width: 160rpx; height: 160rpx; border-radius: 50%;
  border: 2rpx dashed #ddd; background: #f9f9f9;
  display: flex; align-items: center; justify-content: center;
  padding: 0; margin: 0 auto;
  overflow: hidden;
}
.profile-avatar-btn::after { border: none; }
.profile-avatar-img { width: 100%; height: 100%; }
.profile-avatar-hint {
  text-align: center; font-size: 24rpx; color: #bbb;
  margin: 16rpx 0 32rpx;
}
.profile-nick-input {
  width: 100%; height: 80rpx; text-align: center;
  border-bottom: 2rpx solid #eee; font-size: 30rpx;
  margin-bottom: 32rpx;
}
.profile-editor-actions {
  display: flex; gap: 24rpx;
}
.profile-editor-actions van-button { flex: 1; }
.profile-editor-tip {
  margin-top: 24rpx;
  font-size: 22rpx; color: #aaa; line-height: 1.5;
  text-align: center;
}

/* 邀请好友弹层 */
.invite-popup {
  width: 600rpx; background: #fff; border-radius: 24rpx;
  padding: 40rpx 40rpx 32rpx;
}
.invite-title {
  font-size: 32rpx; font-weight: 600; text-align: center; margin-bottom: 32rpx;
}
.invite-qrcode-wrap {
  width: 360rpx; height: 360rpx; margin: 0 auto;
  display: flex; align-items: center; justify-content: center;
  background: #f7f7f7; border-radius: 16rpx;
}
.invite-qrcode { width: 320rpx; height: 320rpx; }
.invite-qrcode-loading { font-size: 24rpx; color: #999; }
.invite-qrcode-tip {
  text-align: center; font-size: 24rpx; color: #999;
  margin-top: 16rpx;
}
.invite-code-row {
  display: flex; align-items: center; justify-content: center;
  margin-top: 32rpx; gap: 16rpx;
}
.invite-code-label { font-size: 26rpx; color: #999; }
.invite-code-value {
  font-size: 36rpx; font-weight: 700; color: #333; letter-spacing: 6rpx;
}
.invite-code-copy {
  font-size: 24rpx; color: #FF5032; padding: 8rpx 16rpx;
  border: 2rpx solid #FF5032; border-radius: 32rpx;
}
.invite-actions {
  display: flex; gap: 24rpx; margin-top: 32rpx;
}
.invite-share-btn {
  flex: 1; height: 80rpx; line-height: 80rpx;
  background: #FF5032; color: #fff; border-radius: 40rpx;
  font-size: 28rpx; font-weight: 600;
}
.invite-share-btn::after { border: none; }
.invite-close-btn {
  flex: 1; height: 80rpx; line-height: 80rpx;
  border: 2rpx solid #eee; border-radius: 40rpx;
  font-size: 28rpx; text-align: center; color: #666;
}

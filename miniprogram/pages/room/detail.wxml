<view class="room-page">
  <!-- 成员横滚 -->
  <view class="users">
    <scroll-view class="users-scroll" scroll-x enable-flex>
      <view class="user-card" wx:for="{{visibleMembers}}" wx:key="userOpenid"
            bindtap="onTapMember" data-openid="{{item.userOpenid}}" data-name="{{item.nickName}}">
        <view class="user-avatar-wrap">
          <view class="user-avatar">
            <image class="user-avatar-img" src="{{item.avatarUrl}}" mode="aspectFill"/>
          </view>
          <van-tag wx:if="{{info.ownerOpenid === item.userOpenid}}" class="owner-tag" type="primary" round color="#f2826a">房主</van-tag>
        </view>
        <view class="user-name">{{item.nickName}}</view>
        <view class="user-score {{aggregated[item.userOpenid] >= 0 ? 'positive' : 'negative'}}">
          {{aggregated[item.userOpenid] >= 0 ? '+' : ''}}{{aggregated[item.userOpenid] || 0}}
        </view>
      </view>

      <!-- 茶水虚拟卡片：点击直接给茶水加分 -->
      <view class="user-card tea-card" bindtap="onTapTea">
        <view class="user-avatar tea-avatar">
          <image src="../../images/tea.png" mode="widthFix" style="width:100%;height:100%"/>
        </view>
        <view class="user-name">茶水费</view>
        <view class="user-score positive">+{{teaTotal || 0}}</view>
      </view>

      <!-- 邀请按钮 -->
      <view class="user-card invite-card" bindtap="onTapInvite">
        <view class="user-avatar invite-avatar">
          <van-icon name="plus" size="56rpx" color="#FF5032"/>
        </view>
        <view class="user-name">邀请好友</view>
        <view class="user-score" style="font-size:24rpx;color:#999">扫码 / 分享</view>
      </view>
    </scroll-view>
  </view>

  <!-- 操作提示 -->
  <view class="action-hint" wx:if="{{!readOnly && info.state === 1}}">
    点自己头像改资料 · 点别人头像转账 · 点茶水图标记茶水费
  </view>

  <!-- 消息流 -->
  <scroll-view class="msg-scroll" scroll-y="{{true}}" scroll-into-view="{{lastMsgId}}">
    <view class="msg-item" wx:for="{{messages}}" wx:key="id" id="msg-{{item.id}}">
      <view class="msg-time">{{item.timeText}}</view>
      <view class="msg-text">
        <text wx:for="{{item.parts}}" wx:for-item="part" wx:key="index" class="msg-part-{{part.type}}">{{part.text}}</text>
      </view>
    </view>
    <van-empty wx:if="{{!messages.length}}" description="暂无记录" />
  </scroll-view>

  <!-- 底部操作栏 -->
  <view class="footer" wx:if="{{!readOnly && info.state === 1}}">
    <view class="footer-btn" bindtap="onLeave">退出</view>
    <view class="footer-btn" wx:if="{{info.ownerOpenid === myOpenid}}" bindtap="onCloseRoom">关闭房间</view>
  </view>

  <!-- 只读提示 -->
  <view class="footer readonly-hint" wx:if="{{readOnly || info.state === 2}}">
    <text>房间 {{info.state === 2 ? '已关闭' : '只读'}}</text>
  </view>

  <!-- 快速计分弹层 -->
  <van-popup show="{{showQuickScore}}" bind:close="onCloseQuickScore" custom-style="background:none">
    <view class="quick-score-popup">
      <view class="quick-score-title">{{quickTargetName}}</view>
      <view class="quick-score-hint">输入你转给 ta 的分数</view>
      <input class="quick-score-input" type="number" placeholder="分数" value="{{quickAmount}}" bindinput="onQuickInput" focus="{{showQuickScore}}"/>
      <view class="quick-score-actions">
        <van-button plain round bindtap="onCloseQuickScore">取消</van-button>
        <van-button type="primary" round color="#FF5032" bindtap="onSubmitQuickScore">确定</van-button>
      </view>
    </view>
  </van-popup>

  <!-- 个人资料编辑弹层 -->
  <van-popup show="{{showProfileEditor}}" bind:close="onCloseProfileEditor" custom-style="background:none">
    <view class="profile-editor">
      <view class="profile-editor-title">编辑个人资料</view>
      <button class="profile-avatar-btn" open-type="chooseAvatar" bindchooseavatar="onEditChooseAvatar">
        <image class="profile-avatar-img" src="{{editAvatarDisplay}}" mode="aspectFill" wx:if="{{editAvatarDisplay}}"/>
        <van-icon name="plus" size="48rpx" color="#ccc" wx:else/>
      </button>
      <view class="profile-avatar-hint">点击更换头像</view>
      <input class="profile-nick-input" type="nickname" placeholder="昵称" value="{{editNickName}}" bindinput="onEditNickInput"/>
      <view class="profile-editor-actions">
        <van-button plain round bindtap="onCloseProfileEditor">取消</van-button>
        <van-button type="primary" round color="#FF5032" bindtap="onSaveProfile">保存</van-button>
      </view>
      <view class="profile-editor-tip">说明：修改后，本房间内已有的记录依然显示原昵称，新房间和新计分会用新昵称。</view>
    </view>
  </van-popup>

  <!-- 邀请好友弹层 -->
  <van-popup show="{{showInvite}}" bind:close="onCloseInvite" custom-style="background:none">
    <view class="invite-popup">
      <view class="invite-title">邀请好友加入</view>
      <view class="invite-qrcode-wrap">
        <image wx:if="{{inviteQrUrl}}" class="invite-qrcode" src="{{inviteQrUrl}}" mode="aspectFit"/>
        <view wx:else class="invite-qrcode-loading">
          <van-loading wx:if="{{!inviteQrError}}" size="48rpx" />
          <text wx:if="{{inviteQrError}}">{{inviteQrError}}</text>
        </view>
      </view>
      <view class="invite-qrcode-tip">微信扫一扫直接进房</view>
      <view class="invite-code-row">
        <text class="invite-code-label">房间码</text>
        <text class="invite-code-value" selectable>{{info.code}}</text>
        <view class="invite-code-copy" bindtap="onCopyCode">复制</view>
      </view>
      <view class="invite-actions">
        <button class="invite-share-btn" open-type="share">微信分享给好友</button>
        <view class="invite-close-btn" bindtap="onCloseInvite">关闭</view>
      </view>
    </view>
  </van-popup>
</view>
